# Enable LDAP auth backend
ENABLE_LDAP_AUTH=true

# LDAP server + bind account
AUTH_LDAP_SERVER_URI=ldap://ldap.example.com:389
AUTH_LDAP_START_TLS=false
AUTH_LDAP_BIND_DN=cn=svc_bind,ou=service,dc=example,dc=com
AUTH_LDAP_BIND_PASSWORD=replace_me

# User search
# For Active Directory, common filter: (sAMAccountName=%(user)s)
# For OpenLDAP, common filter: (uid=%(user)s)
AUTH_LDAP_USER_BASE_DN=ou=users,dc=example,dc=com
AUTH_LDAP_USER_FILTER=(uid=%(user)s)

# Attribute mapping (optional overrides)
AUTH_LDAP_ATTR_FIRST_NAME=givenName
AUTH_LDAP_ATTR_LAST_NAME=sn
AUTH_LDAP_ATTR_EMAIL=mail
AUTH_LDAP_ALWAYS_UPDATE_USER=true

# Optional group controls
AUTH_LDAP_GROUP_BASE_DN=ou=groups,dc=example,dc=com
AUTH_LDAP_GROUP_FILTER=(objectClass=groupOfNames)
AUTH_LDAP_REQUIRE_GROUP_DN=
AUTH_LDAP_MANAGER_GROUP_DN=cn=calendar-managers,ou=groups,dc=example,dc=com

# LDAP result cache seconds
AUTH_LDAP_CACHE_TIMEOUT=3600
